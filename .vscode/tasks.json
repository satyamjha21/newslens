{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1️⃣ Setup: Create venv + install deps (Windows)",
      "type": "shell",
      "command": "python -m venv .venv && .venv\\Scripts\\pip install -r requirements.txt",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "echo": true, "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "1️⃣ Setup: Create venv + install deps (Mac/Linux)",
      "type": "shell",
      "command": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "echo": true, "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "2️⃣ Copy .env.example → .env (Windows)",
      "type": "shell",
      "command": "if not exist .env copy .env.example .env && echo .env created — open it and add your GEMINI_API_KEY",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "echo": true, "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "2️⃣ Copy .env.example → .env (Mac/Linux)",
      "type": "shell",
      "command": "[ -f .env ] || cp .env.example .env && echo '.env created — open it and add your GEMINI_API_KEY'",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "echo": true, "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "3️⃣ Start Backend (Windows)",
      "type": "shell",
      "command": ".venv\\Scripts\\uvicorn.exe main:app --reload --host 127.0.0.1 --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Started reloader",
          "endsPattern": "Application startup complete"
        }
      }
    },
    {
      "label": "3️⃣ Start Backend (Mac/Linux)",
      "type": "shell",
      "command": ".venv/bin/uvicorn main:app --reload --host 127.0.0.1 --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      },
      "problemMatcher": []
    },
    {
      "label": "🧪 Run Tests",
      "type": "shell",
      "command": ".venv\\Scripts\\python -m pytest tests/ -v --tb=short",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": { "DISABLE_PIPELINES": "1" }
      },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "🧪 Run Tests (Mac/Linux)",
      "type": "shell",
      "command": ".venv/bin/python3 -m pytest tests/ -v --tb=short",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": { "DISABLE_PIPELINES": "1" }
      },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    }
  ]
}
